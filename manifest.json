{
    "name": "Test PWA",
    "short_name": "TPWA",
    "start_url": "./index.html",
    "scope": "./",
    "display": "standalone",
    "share_target": {
        "action": "./share-target",
        "method": "POST",
        "enctype": "multipart/form-data",
        "params": {
            "title": "title",
            "text": "text",
            "url": "url",
            "files": [
                {
                    "name": "files",
                    "accept": ["image/*", "text/*", "application/pdf"]
                }
            ]
        }
    },
    "icons": [
        {
            "src": "image.png",
            "sizes": "500x500",
            "type": "image/png",
            "purpose": "any"
        }
    ]
}
